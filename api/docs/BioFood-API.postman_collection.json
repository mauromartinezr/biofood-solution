              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "{{studentId}}", "profile"]
            },
            "description": "GET /api/students/:id/profile — `id` = `usuario_identificacion`. 404 si no existe."
          },
          "response": []
        },
        {
          "name": "10 — Historial transacciones",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/students/{{studentId}}/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "{{studentId}}", "transactions"]
            },
            "description": "GET /api/students/:id/transactions — Últimas 20 transacciones (fecha desc)."
          },
          "response": []
        },
        {
          "name": "11 — Top 3 productos del estudiante",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/students/{{studentId}}/top-products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "{{studentId}}", "top-products"]
            },
            "description": "GET /api/students/:id/top-products — Solo compras con cantidad > 0."
          },
          "response": []
        },
        {
          "name": "12 — Consumo semanal (nutrición)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/students/{{studentId}}/nutrition",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "{{studentId}}", "nutrition"]
            },
            "description": "GET /api/students/:id/nutrition — Unidades por producto (últimos 7 días)."
          },
          "response": []
        },
        {
          "name": "13 — Análisis transaccional diario",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/students/{{studentId}}/analysis",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "{{studentId}}", "analysis"]
            },
            "description": "GET /api/students/:id/analysis — Gasto diario últimos 30 días."
          },
          "response": []
        }
      ]
    }
  ]
}
